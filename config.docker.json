{
  "logging": {
    "logLevel": "info",
    "format": "json",
    "outputPath": "stdout"
  },
  "receiver": {
    "host": "0.0.0.0",
    "httpPort": 4318,
    "grpcPort": 4317,
    "maxBodySize": 4194304,
    "requestTimeoutSecs": 30
  },
  "outputs": [
    {
      "Type": "nlog",
      "ConfigFile": "nlog.config"
    }
  ],
  "service": {
    "name": "Log4TcService",
    "displayName": "Log4TC Logging Service",
    "workerThreads": null,
    "channelCapacity": 10000,
    "shutdownTimeoutSecs": 30
  }
}
