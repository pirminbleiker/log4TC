{
  "logging": {
    "logLevel": "info",
    "format": "json",
    "outputPath": "stdout"
  },
  "receiver": {
    "host": "0.0.0.0",
    "httpPort": 4318,
    "grpcPort": 4317,
    "maxBodySize": 4194304,
    "requestTimeoutSecs": 30,
    "amsNetId": "0.0.0.0.1.1",
    "amsTcpPort": 48898,
    "adsPort": 16150
  },
  "outputs": [
    {
      "Type": "nlog",
      "ConfigFile": "nlog.config"
    },
    {
      "Type": "graylog",
      "Host": "localhost",
      "Port": 12201,
      "Protocol": "UDP",
      "Facility": "LOG4TC"
    }
  ],
  "service": {
    "name": "Log4TcService",
    "displayName": "Log4TC Logging Service",
    "workerThreads": null,
    "channelCapacity": 10000,
    "shutdownTimeoutSecs": 30
  }
}
